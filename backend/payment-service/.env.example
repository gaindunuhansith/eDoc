# Server
SERVER_PORT=8085

# Database (preferred single URL)
DB_URL=jdbc:postgresql://localhost:5437/payment_db
DB_USER=user
DB_PASSWORD=password

# PayHere
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_MERCHANT_SECRET=your_merchant_secret
PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout
PAYHERE_NOTIFY_URL=http://localhost:8085/api/v1/payments/webhook/notify

# Inter-service
APPOINTMENT_SERVICE_URL=http://appointment-service:8081

# Security (RS256 public key location in Spring resource notation)
JWT_PUBLIC_KEY_LOCATION=classpath:public.pem

# Spring profile
SPRING_PROFILES_ACTIVE=local